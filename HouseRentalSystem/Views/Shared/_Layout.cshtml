@using Microsoft.AspNetCore.Identity
@using HouseRentalSystem.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HouseRentalSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HouseRentalSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3" style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-home me-2"></i>HouseRental
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                       

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i> Home
                            </a>
                        </li>

                        <!-- Quick Search in Navbar (Mobile friendly) -->
                        <li class="nav-item d-md-none">
                            <form asp-controller="Houses" asp-action="Browse" method="get" class="d-flex">
                                <input type="text" name="searchString" class="form-control me-2" placeholder="Search properties..." style="max-width: 150px;">
                                <button type="submit" class="btn btn-warning btn-sm">
                                    <i class="fas fa-search"></i>
                                </button>
                            </form>
                        </li>

                        <!-- Navigation for authenticated users -->
                        @if (User.Identity.IsAuthenticated)
                        {
                            var user = await UserManager.GetUserAsync(User);
                            if (user?.IsHouseOwner == true)
                            {
                                <!-- House Owner Navigation -->
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Houses" asp-action="Index">
                                        <i class="fas fa-building me-1"></i> My Properties
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Houses" asp-action="Create">
                                        <i class="fas fa-plus-circle me-1"></i> Add Property
                                    </a>
                                </li>
                            }
                            else
                            {
                                <!-- Tenant Navigation -->
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Houses" asp-action="Browse">
                                        <i class="fas fa-search me-1"></i> Browse Properties
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Houses" asp-action="MyApplications">
                                        <i class="fas fa-clipboard-list me-1"></i> My Applications
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <!-- Public Navigation for non-authenticated users -->
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Houses" asp-action="Browse">
                                    <i class="fas fa-search me-1"></i> Browse Properties
                                </a>
                            </li>
                        }
                        <!-- Search Engine - First Position -->
                        <li class="nav-item">
                            <form asp-controller="Houses" asp-action="Browse" method="get" class="d-flex me-3">
                                <div class="input-group" style="max-width: 250px;">
                                    <input type="text" name="searchString" class="form-control" placeholder="Search properties...">
                                    <button type="submit" class="btn btn-warning">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </form>
                        </li>
                    </ul>

                    <!-- Add the login partial here -->
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

   
    

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - HouseRentalSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>