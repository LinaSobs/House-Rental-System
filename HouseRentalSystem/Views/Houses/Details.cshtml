@model HouseRentalSystem.Models.House

@{
    ViewData["Title"] = "Property Details";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <!-- Header Section -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header py-4" style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-center text-md-start">
                                <i class="fas fa-home fa-3x text-white mb-3"></i>
                                <h1 class="h2 text-white mb-1">Property Details</h1>
                                <p class="text-white-50 mb-0">Complete property information and specifications</p>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@Model.HouseId" class="btn text-white" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);">
                                    <i class="fas fa-edit me-2"></i>Edit
                                </a>
                                <a asp-action="Index" class="btn text-white" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);">
                                    <i class="fas fa-arrow-left me-2"></i>Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Property Images Table -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <h5 class="text-primary mb-0">
                        <i class="fas fa-images me-2"></i>Property Images
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                                <tr class="text-white">
                                    <th class="ps-4">
                                        <i class="fas fa-image me-2"></i>Image Type
                                    </th>
                                    <th>
                                        <i class="fas fa-eye me-2"></i>Preview
                                    </th>
                                    <th class="pe-4">
                                        <i class="fas fa-info-circle me-2"></i>Status
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4">
                                        <strong>Main Image</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.ImagePath1))
                                        {
                                            <img src="@Model.ImagePath1" class="rounded" alt="Main image" style="width: 120px; height: 80px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 120px; height: 80px;">
                                                <i class="fas fa-image text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="pe-4">
                                        <span class="badge @(!string.IsNullOrEmpty(Model.ImagePath1) ? "bg-success" : "bg-secondary")">
                                            @(!string.IsNullOrEmpty(Model.ImagePath1) ? "Uploaded" : "Not Available")
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <strong>Second Image</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.ImagePath2))
                                        {
                                            <img src="@Model.ImagePath2" class="rounded" alt="Second image" style="width: 120px; height: 80px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 120px; height: 80px;">
                                                <i class="fas fa-image text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="pe-4">
                                        <span class="badge @(!string.IsNullOrEmpty(Model.ImagePath2) ? "bg-success" : "bg-secondary")">
                                            @(!string.IsNullOrEmpty(Model.ImagePath2) ? "Uploaded" : "Not Available")
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4">
                                        <strong>Third Image</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.ImagePath3))
                                        {
                                            <img src="@Model.ImagePath3" class="rounded" alt="Third image" style="width: 120px; height: 80px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 120px; height: 80px;">
                                                <i class="fas fa-image text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="pe-4">
                                        <span class="badge @(!string.IsNullOrEmpty(Model.ImagePath3) ? "bg-success" : "bg-secondary")">
                                            @(!string.IsNullOrEmpty(Model.ImagePath3) ? "Uploaded" : "Not Available")
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Basic Information Table -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <h5 class="text-primary mb-0">
                        <i class="fas fa-info-circle me-2"></i>Basic Information
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                                <tr class="text-white">
                                    <th class="ps-4" style="width: 25%;">
                                        <i class="fas fa-tag me-2"></i>Field
                                    </th>
                                    <th style="width: 75%;">
                                        <i class="fas fa-info me-2"></i>Details
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4 fw-bold">Property Title</td>
                                    <td>@Model.Title</td>
                                </tr>
                                <tr>
                                    <td class="ps-4 fw-bold">Description</td>
                                    <td>@Model.Description</td>
                                </tr>
                                <tr>
                                    <td class="ps-4 fw-bold">Monthly Rent</td>
                                    <td class="text-success fw-bold">R @Model.Price.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td class="ps-4 fw-bold">Availability Status</td>
                                    <td>
                                        <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary") px-3 py-2">
                                            <i class="fas @(Model.IsAvailable ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                                            @(Model.IsAvailable ? "Available for Rent" : "Currently Rented")
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Location Information Table -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <h5 class="text-primary mb-0">
                        <i class="fas fa-map-marker-alt me-2"></i>Location Information
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                                <tr class="text-white">
                                    <th class="ps-4" style="width: 25%;">
                                        <i class="fas fa-location-arrow me-2"></i>Address Field
                                    </th>
                                    <th style="width: 75%;">
                                        <i class="fas fa-map-pin me-2"></i>Location Details
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4 fw-bold">Street Address</td>
                                    <td>@Model.Address</td>
                                </tr>
                                <tr>
                                    <td class="ps-4 fw-bold">City</td>
                                    <td>@Model.City</td>
                                </tr>
                                <tr>
                                    <td class="ps-4 fw-bold">Postal Code</td>
                                    <td>@Model.ZipCode</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Property Specifications Table -->
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <h5 class="text-primary mb-0">
                        <i class="fas fa-home me-2"></i>Property Specifications
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                                <tr class="text-white text-center">
                                    <th class="ps-4">
                                        <i class="fas fa-bed me-2"></i>Bedrooms
                                    </th>
                                    <th>
                                        <i class="fas fa-bath me-2"></i>Bathrooms
                                    </th>
                                    <th>
                                        <i class="fas fa-ruler-combined me-2"></i>Area (m²)
                                    </th>
                                    <th class="pe-4">
                                        <i class="fas fa-clipboard-list me-2"></i>Applications
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="text-center">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="fas fa-bed text-primary fa-2x me-3"></i>
                                            <div>
                                                <h4 class="mb-0 text-primary">@Model.Bedrooms</h4>
                                                <small class="text-muted">Bedrooms</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="fas fa-bath text-primary fa-2x me-3"></i>
                                            <div>
                                                <h4 class="mb-0 text-primary">@Model.Bathrooms</h4>
                                                <small class="text-muted">Bathrooms</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="fas fa-ruler-combined text-primary fa-2x me-3"></i>
                                            <div>
                                                <h4 class="mb-0 text-primary">@Model.Area</h4>
                                                <small class="text-muted">Square Meters</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="fas fa-clipboard-list text-primary fa-2x me-3"></i>
                                            <div>
                                                <h4 class="mb-0 text-primary">@Model.RentalApplications.Count</h4>
                                                <small class="text-muted">Applications</small>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Features & Amenities Table -->
            <div class="card shadow-lg border-0">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <h5 class="text-primary mb-0">
                        <i class="fas fa-star me-2"></i>Features & Amenities
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                                <tr class="text-white text-center">
                                    <th class="ps-4" style="width: 50%;">
                                        <i class="fas fa-check-circle me-2"></i>Available Features
                                    </th>
                                    <th class="pe-4" style="width: 50%;">
                                        <i class="fas fa-times-circle me-2"></i>Additional Features
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4">
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="fas @(Model.HasParking ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.HasParking ? "text-success" : "text-danger")">Parking Available</span>
                                                </div>
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="fas @(Model.HasGarden ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.HasGarden ? "text-success" : "text-danger")">Garden</span>
                                                </div>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas @(Model.HasPool ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.HasPool ? "text-success" : "text-danger")">Swimming Pool</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="pe-4">
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="fas @(Model.HasFurniture ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.HasFurniture ? "text-success" : "text-danger")">Furnished</span>
                                                </div>
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="fas @(Model.HasWiFi ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.HasWiFi ? "text-success" : "text-danger")">WiFi Included</span>
                                                </div>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas @(Model.PetsAllowed ? "fa-check-circle text-success" : "fa-times-circle text-danger") me-3 fa-lg"></i>
                                                    <span class="fw-bold @(Model.PetsAllowed ? "text-success" : "text-danger")">Pets Allowed</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }

    .card-header {
        border-radius: 15px 15px 0 0 !important;
        border: none;
    }

    .table thead th {
        border: none;
        font-weight: 600;
        padding: 1rem;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 1rem;
        border-color: #dee2e6;
    }

    .btn {
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
        }

    .badge {
        border-radius: 20px;
        font-weight: 600;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }

    .text-primary {
        color: #0d6efd !important;
    }

    .fa-2x {
        font-size: 1.8em;
    }

    .fa-lg {
        font-size: 1.3em;
    }
</style>