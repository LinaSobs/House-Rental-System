@model HouseRentalSystem.Models.House

@{
    ViewData["Title"] = "Delete Property";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h2 class="card-title mb-0">Delete Property</h2>
                </div>
                <div class="card-body">
                    <h3 class="text-danger">Are you sure you want to delete this property?</h3>
                    <p class="text-muted">This action cannot be undone. All associated rental applications will also be deleted.</p>

                    <div class="alert alert-warning">
                        <h5>Property Details:</h5>
                        <dl class="row">
                            <dt class="col-sm-4">Title:</dt>
                            <dd class="col-sm-8">@Model.Title</dd>

                            <dt class="col-sm-4">Address:</dt>
                            <dd class="col-sm-8">@Model.Address, @Model.City</dd>

                            <dt class="col-sm-4">Price:</dt>
                            <dd class="col-sm-8">R @Model.Price.ToString("N2")/month</dd>

                            <dt class="col-sm-4">Bedrooms/Bathrooms:</dt>
                            <dd class="col-sm-8">@Model.Bedrooms bed, @Model.Bathrooms bath</dd>

                            <dt class="col-sm-4">Area:</dt>
                            <dd class="col-sm-8">@Model.Area m²</dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
                                    @(Model.IsAvailable ? "Available" : "Rented")
                                </span>
                            </dd>

                            <dt class="col-sm-4">Rental Applications:</dt>
                            <dd class="col-sm-8">@Model.RentalApplications.Count</dd>
                        </dl>
                    </div>

                    @if (Model.RentalApplications.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Warning!</strong> This property has @Model.RentalApplications.Count rental application(s).
                            Deleting this property will also delete all associated rental applications.
                        </div>
                    }

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="HouseId" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete Property
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>