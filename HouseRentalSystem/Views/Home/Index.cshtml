@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Home - Find Your Perfect Rental";
}

<!-- Hero Section -->
<section class="hero-section bg-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">Find Your Perfect Home</h1>
                <p class="lead mb-4">Discover amazing rental properties in your desired location. From cozy apartments to spacious family homes, we have something for everyone.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Houses" asp-action="Browse" class="btn btn-light btn-lg px-4">
                        <i class="fas fa-search me-2"></i>Browse Properties
                    </a>
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg px-4">
                            <i class="fas fa-user-plus me-2"></i>Join Now
                        </a>
                    }
                    else
                    {
                        var userManager = Context.RequestServices.GetService<UserManager<ApplicationUser>>();
                        var user = await userManager.GetUserAsync(User);
                        if (user?.IsHouseOwner == true)
                        {
                            <a asp-controller="Houses" asp-action="Create" class="btn btn-outline-light btn-lg px-4">
                                <i class="fas fa-plus-circle me-2"></i>List Your Property
                            </a>
                        }
                    }
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image mt-4 mt-lg-0">
                    <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80"
                         alt="Beautiful Home" class="img-fluid rounded-3 shadow">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-12">
                <h2 class="fw-bold mb-3">Why Choose Our Platform?</h2>
                <p class="text-muted lead">We make renting simple and secure for everyone</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-home fa-2x"></i>
                    </div>
                    <h4>Verified Properties</h4>
                    <p class="text-muted">All properties are verified by our team to ensure quality and authenticity.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-shield-alt fa-2x"></i>
                    </div>
                    <h4>Secure Payments</h4>
                    <p class="text-muted">Safe and secure payment processing with Stripe integration.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-headset fa-2x"></i>
                    </div>
                    <h4>24/7 Support</h4>
                    <p class="text-muted">Our support team is always here to help you with any questions.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Properties Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="fw-bold text-center mb-3">Featured Properties</h2>
                <p class="text-muted text-center lead">Discover some of our most popular rental properties</p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Property 1 -->
            <div class="col-md-4">
                <div class="card property-card h-100 shadow-sm">
                    <div class="property-image position-relative">
                        <img src="https://images.unsplash.com/photo-1518780664697-55e3ad937233?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80"
                             class="card-img-top" alt="Modern Apartment" style="height: 250px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark">Just Listed</span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Modern City Apartment</h5>
                        <p class="card-text text-muted">
                            <i class="fas fa-map-marker-alt me-1"></i> Pretoria Central, Gauteng
                        </p>
                        <div class="property-features mb-3">
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bed me-1"></i>2 Bed</span>
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bath me-1"></i>1 Bath</span>
                            <span class="badge bg-light text-dark"><i class="fas fa-ruler-combined me-1"></i>85 m²</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">R 8,500/m</span>
                            <a href="#" class="btn btn-outline-primary btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Property 2 -->
            <div class="col-md-4">
                <div class="card property-card h-100 shadow-sm">
                    <div class="property-image position-relative">
                        <img src="https://images.unsplash.com/photo-1568605114967-8130f3a36994?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80"
                             class="card-img-top" alt="Family House" style="height: 250px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark">Just Listed</span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Spacious Family Home</h5>
                        <p class="card-text text-muted">
                            <i class="fas fa-map-marker-alt me-1"></i> Sandton, Johannesburg
                        </p>
                        <div class="property-features mb-3">
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bed me-1"></i>4 Bed</span>
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bath me-1"></i>3 Bath</span>
                            <span class="badge bg-light text-dark"><i class="fas fa-ruler-combined me-1"></i>220 m²</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">R 18,000/m</span>
                            <a href="#" class="btn btn-outline-primary btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Property 3 -->
            <div class="col-md-4">
                <div class="card property-card h-100 shadow-sm">
                    <div class="property-image position-relative">
                        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80"
                             class="card-img-top" alt="Luxury Villa" style="height: 250px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark">Just Listed</span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Luxury Garden Villa</h5>
                        <p class="card-text text-muted">
                            <i class="fas fa-map-marker-alt me-1"></i> Claremont, Cape Town
                        </p>
                        <div class="property-features mb-3">
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bed me-1"></i>3 Bed</span>
                            <span class="badge bg-light text-dark me-1"><i class="fas fa-bath me-1"></i>2 Bath</span>
                            <span class="badge bg-light text-dark"><i class="fas fa-ruler-combined me-1"></i>180 m²</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">R 25,000/m</span>
                            <a href="#" class="btn btn-outline-primary btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Houses" asp-action="Browse" class="btn btn-primary btn-lg">
                <i class="fas fa-search me-2"></i>View All Properties
            </a>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="py-5">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="fw-bold text-center mb-3">How It Works</h2>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        1
                    </div>
                    <h4>Browse & Apply</h4>
                    <p class="text-muted">Find your perfect rental property and submit your application online.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        2
                    </div>
                    <h4>Get Approved</h4>
                    <p class="text-muted">Property owners review applications and approve qualified tenants.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        3
                    </div>
                    <h4>Secure & Move In</h4>
                    <p class="text-muted">Make your payment securely and move into your new home!</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action Section -->
<section class="py-5 bg-dark text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h3 class="fw-bold mb-3">Ready to Find Your New Home?</h3>
                <p class="lead mb-0">Join thousands of happy tenants and property owners using our platform.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg px-4">
                        <i class="fas fa-user-plus me-2"></i>Get Started Today
                    </a>
                }
                else
                {
                    <a asp-controller="Houses" asp-action="Browse" class="btn btn-light btn-lg px-4">
                        <i class="fas fa-search me-2"></i>Browse Properties
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<style>
    .hero-section {
        background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
    }

    .property-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
    }

        .property-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }

    .feature-icon, .step-number {
        transition: transform 0.3s ease;
    }

        .feature-icon:hover, .step-number:hover {
            transform: scale(1.1);
        }
</style>