@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark text-center">
                    <i class="bi bi-x-circle-fill display-4"></i>
                    <h2 class="card-title mb-0 mt-2">Payment Cancelled</h2>
                </div>
                <div class="card-body text-center">
                    @if (TempData["Info"] != null)
                    {
                        <div class="alert alert-info">
                            <h4>@TempData["Info"]</h4>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <h4>Payment was cancelled</h4>
                            <p class="mb-0">You can complete your payment later from your applications page.</p>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Houses" asp-action="MyApplications" class="btn btn-primary me-2">
                            Back to My Applications
                        </a>
                        <a asp-controller="Houses" asp-action="Browse" class="btn btn-outline-secondary">
                            Browse Properties
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
